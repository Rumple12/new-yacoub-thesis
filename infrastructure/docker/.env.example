# Copy this file to .env before running Docker Compose.
#
# This baseline is for local PC development. Do not commit .env if it contains
# real credentials or a real encryption key.

# Host port exposed on the development machine.
N8N_HOST_PORT=5678

# Local access settings.
N8N_HOST=localhost
N8N_SECURE_COOKIE=false

# Replace before real use. Keep the same value across restarts so saved
# credentials can still be decrypted.
N8N_ENCRYPTION_KEY=replace-with-a-long-random-local-development-key

# Thesis timezone.
GENERIC_TIMEZONE=Europe/Stockholm

# Keep the baseline quiet and reproducible.
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
