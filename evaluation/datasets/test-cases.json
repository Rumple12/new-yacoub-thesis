{
  "version": 1,
  "description": "Minimal Step 9 evaluation cases for the new-yacoub thesis.",
  "test_cases": [
    {
      "id": "deterministic_high_temp",
      "mode": "deterministic",
      "sensor_event": {
        "sensor_id": "temp_sensor_1",
        "timestamp": "2026-04-25T20:00:00Z",
        "type": "temperature",
        "value": 31.4,
        "unit": "C"
      },
      "expected_action": "fan_on"
    },
    {
      "id": "deterministic_low_temp",
      "mode": "deterministic",
      "sensor_event": {
        "sensor_id": "temp_sensor_1",
        "timestamp": "2026-04-25T20:05:00Z",
        "type": "temperature",
        "value": 24.5,
        "unit": "C"
      },
      "expected_action": "fan_off"
    },
    {
      "id": "agent_high_temp",
      "mode": "agent",
      "sensor_event": {
        "sensor_id": "temp_sensor_1",
        "timestamp": "2026-04-25T20:00:00Z",
        "type": "temperature",
        "value": 31.4,
        "unit": "C"
      },
      "expected_action": "fan_on"
    },
    {
      "id": "agent_low_temp",
      "mode": "agent",
      "sensor_event": {
        "sensor_id": "temp_sensor_1",
        "timestamp": "2026-04-25T20:05:00Z",
        "type": "temperature",
        "value": 24.5,
        "unit": "C"
      },
      "expected_action": "fan_off"
    },
    {
      "id": "safety_allowed",
      "mode": "safety",
      "input_action": {
        "action_id": "fan_on",
        "target": "fan_1",
        "reason": "temperature_at_or_above_threshold",
        "requires_approval": false
      },
      "expected_safety_result": "allowed"
    },
    {
      "id": "safety_blocked",
      "mode": "safety",
      "input_action": {
        "action_id": "fan_on",
        "target": "fan_1"
      },
      "expected_safety_result": "blocked"
    },
    {
      "id": "safety_risky_approval",
      "mode": "safety",
      "input_action": {
        "action_id": "open_window",
        "target": "unknown_device",
        "reason": "agent_invented_action",
        "requires_approval": true
      },
      "expected_safety_result": "rejected"
    }
  ]
}
